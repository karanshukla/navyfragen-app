# Copy this file to .env and fill in the required values.
# Generate secrets with: openssl rand -hex 32

# ── Required ──────────────────────────────────────────────────────────────────

# AES-256 key for encrypting OAuth tokens
OAUTH_TOKEN_SECRET=

# Secret for signing session cookies
COOKIE_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Public-facing URL of the app (used for Bluesky OAuth client metadata).
# Bluesky OAuth works on localhost — no tunnel needed for local testing.
# PUBLIC_URL=http://localhost:8080

# PostgreSQL credentials (defaults work out of the box)
# POSTGRES_USER=navyfragen
# POSTGRES_PASSWORD=navyfragen
# POSTGRES_DB=navyfragen

# ── E2E Testing (never set these in production) ───────────────────────────────
# Used only with docker-compose.e2e.yml overlay. See docs/e2e-testing.md.
# This file is gitignored — it is safe to put credentials here.
# Playwright reads these from docker/.env automatically (no manual sourcing needed).
#
# E2E_PDS_URL=https://bsky.social
# E2E_HANDLE=yourhandle.bsky.social
# E2E_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
