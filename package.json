{
    "name": "navyfragen-monorepo",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm:dev --workspace=client\" \"npm:dev --workspace=server\" \"npm --prefix html-to-image start\"",
        "html-to-image": "docker compose -f docker/docker-compose.yml up html-to-image --build",
        "prepare": "husky || true",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "concurrently": "^8.2.2",
        "happy-dom": "^20.10.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.3"
    },
    "dependencies": {
        "@types/ws": "^8.18.1",
        "ws": "^8.21.0"
    },
    "overrides": {
        "esbuild": ">=0.28.1"
    }
}
