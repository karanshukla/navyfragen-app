{
  "name": "navyfragen-server",
  "version": "1.0.0",
  "description": "For answering anonymous questions and posting them to Bluesky",
  "author": "Karan Shukla",
  "license": "MIT",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts | pino-pretty",
    "build": "tsup",
    "start": "node dist/index.js",
    "postinstall": "npm run build",
    "lexgen": "lex gen-server ./src/lexicon ./lexicons/*",
    "clean": "rimraf dist coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "node --import ./src/tests/test-bootstrap.js --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import ./src/tests/test-bootstrap.js --import tsx --watch --test src/**/*.test.ts",
    "test:coverage": "c8 node --import ./src/tests/test-bootstrap.js --import tsx --test src/**/*.test.ts",
    "publish-lexicons": "tsx --tsconfig tsconfig.json src/scripts/publish-lexicons.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "oxlint --fix"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "include": [
      "src/**"
    ],
    "exclude": [
      "src/lexicon/**",
      "src/index.ts",
      "src/auth/client.ts",
      "src/auth/e2e-agent-store.ts",
      "src/auth/storage.ts",
      "src/auth/session.ts",
      "src/database/db.ts",
      "src/lib/id-resolver.ts",
      "src/lib/env.ts",
      "src/routes.ts",
      "src/routes/*.ts",
      "src/scripts/**"
    ]
  },
  "dependencies": {
    "@atproto/api": "^0.20.25",
    "@atproto/common": "^0.7.0",
    "@atproto/identity": "^0.5.3",
    "@atproto/lexicon": "^0.7.4",
    "@atproto/oauth-client-node": "^0.4.5",
    "@atproto/sync": "^0.3.7",
    "@atproto/syntax": "^0.7.0",
    "@atproto/xrpc-server": "^0.11.6",
    "@axiomhq/pino": "^1.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-session": "^2.0.49",
    "@types/cryptr": "^4.0.3",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "cryptr": "^6.4.0",
    "dotenv": "^17.4.2",
    "envalid": "^8.2.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "iron-session": "^8.0.4",
    "kysely": "^0.28.17",
    "multiformats": "^14.0.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "sharp": "^0.35.3",
    "uhtml": "^5.0.9",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.10.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/pg": "^8.20.0",
    "@types/serve-static": "^2.2.0",
    "c8": "^11.0.0",
    "oxlint": "^1.73.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "tsup": {
    "entry": [
      "src",
      "!src/**/__tests__/**",
      "!src/**/*.test.*"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true
  }
}
