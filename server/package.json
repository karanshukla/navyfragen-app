{
  "name": "navyfragen-server",
  "version": "1.0.0",
  "description": "For answering anonymous questions and posting them to Bluesky",
  "author": "Karan Shukla",
  "license": "MIT",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts | pino-pretty",
    "build": "tsup",
    "start": "node dist/index.js",
    "postinstall": "npm run build",
    "lexgen": "lex gen-server ./src/lexicon ./lexicons/*",
    "clean": "rimraf dist coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "node --import ./src/tests/test-bootstrap.js --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import ./src/tests/test-bootstrap.js --import tsx --watch --test src/**/*.test.ts",
    "test:coverage": "c8 node --import ./src/tests/test-bootstrap.js --import tsx --test src/**/*.test.ts",
    "publish-lexicons": "tsx --tsconfig tsconfig.json src/scripts/publish-lexicons.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "include": [
      "src/**"
    ],
    "exclude": [
      "src/lexicon/**",
      "src/index.ts",
      "src/auth/client.ts",
      "src/auth/storage.ts",
      "src/auth/session.ts",
      "src/database/db.ts",
      "src/lib/id-resolver.ts",
      "src/lib/env.ts",
      "src/routes.ts",
      "src/routes/*.ts",
      "src/scripts/**"
    ]
  },
  "dependencies": {
    "@atproto/api": "^0.19.19",
    "@atproto/common": "^0.5.16",
    "@atproto/identity": "^0.4.12",
    "@atproto/lexicon": "^0.6.2",
    "@atproto/oauth-client-node": "^0.3.17",
    "@atproto/sync": "^0.2.4",
    "@atproto/syntax": "^0.5.4",
    "@atproto/xrpc-server": "^0.10.22",
    "@axiomhq/pino": "^1.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-session": "^2.0.49",
    "@types/cryptr": "^4.0.3",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "cryptr": "^6.4.0",
    "dotenv": "^16.6.1",
    "envalid": "^8.1.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "iron-session": "^8.0.4",
    "kysely": "^0.28.12",
    "multiformats": "^9.9.0",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "sharp": "^0.34.5",
    "uhtml": "^4.7.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.10.2",
    "@eslint/compat": "^2.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/pg": "^8.20.0",
    "@types/serve-static": "^1.15.10",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "c8": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "pino-pretty": "^11.3.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "tsup": {
    "entry": [
      "src",
      "!src/**/__tests__/**",
      "!src/**/*.test.*"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true
  }
}
