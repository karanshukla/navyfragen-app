#!/bin/sh

# Auto-fix staged files with Prettier and ESLint.
# Run per-workspace so each picks up its own ESLint v10 config.
(cd client && npx lint-staged --allow-empty)
(cd server && npx lint-staged --allow-empty)

# TypeScript type check — catches errors auto-fix can't resolve
echo "TypeScript: client..."
npm run typecheck -w client

echo "TypeScript: server..."
npm run typecheck -w server